{
  "name": "@panitw/todo4-openclaw-plugin",
  "version": "0.4.0",
  "type": "module",
  "description": "OpenClaw plugin that onboards Todo4 from chat and ships an MCP-aware work skill.",
  "license": "MIT",
  "author": "Panit Wechasil",
  "homepage": "https://github.com/panitw/todo4-openclaw-plugin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panitw/todo4-openclaw-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/panitw/todo4-openclaw-plugin/issues"
  },
  "keywords": ["openclaw", "openclaw-plugin", "todo4", "mcp", "task-management"],
  "files": [
    "index.ts",
    "src/**/*.ts",
    "skills/**/*.md",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": ["./index.ts"],
    "compat": { "pluginApi": ">=2026.3.24-beta.2" },
    "build": {
      "openclawVersion": "2026.4.11",
      "pluginSdkVersion": "2026.4.11"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
